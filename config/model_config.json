{
  "data_root": "../base_data",
  "output_root": "../output",
  "base_roi_root": "../base_data",
  "vegetation_config": "../config/vegetation_config.json",
  "classifier_ckpt": "../models/multiclass_roi_classifier/best.pt",
  "binary_classifier_ckpt": "../models/binary_roi_classifier/best.pt",
  "mobile_sam_ckpt": "../models/backbones/mobile_sam.pt",
  "superpoint_ckpt": "../models/matching/superpoint_v1.pth",
  "classifier_device": "cuda:0",
  "binary_classifier_device": "cuda:0",
  "allowed_labels": [
    "rock_spalling",
    "slope_plant",
    "other_plant"
  ],
  "min_change_pixels": 800,
  "min_change_ratio": 0.001,
  "min_instance_pixels": 1000,
  "require_raw_change_for_instances": false,
  "classifier_confidence_threshold": 0.6,
  "binary_classifier_change_threshold": 0.5,
  "update_base_on_change": true,
  "test_dataset": "ChangeVPR",
  "output_size": 512,
  "feature_facet": "key",
  "feature_layer": 17,
  "embedding_layer": 32,
  "sam_backbone": "vit_t",
  "points_per_side": 32,
  "pred_iou_thresh": 0.7,
  "stability_score_thresh": 0.7,
  "pseudo_backbone": "vit_t",
  "adaptive_threshold_mode": "hysteresis",
  "adaptive_threshold_min": 0.8,
  "adaptive_threshold_max": 3.0,
  "adaptive_threshold_mad_eps": 1e-6,
  "adaptive_threshold_sim_std_eps": 1e-6,
  "enable_yolo_detection": false,
  "yolo_config": ""
}
